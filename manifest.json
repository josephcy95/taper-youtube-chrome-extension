{
  "manifest_version": 3,
  "name": "Taper",
  "version": "0.1.0",
  "description": "Limit YouTube Shorts with rolling count and time caps.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Taper"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
